{
  "name": "appshot-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render AppPreview out/AppPreview.mp4",
    "build:gif": "remotion render AppPreview out/AppPreview.gif --image-format png",
    "build:portrait": "remotion render AppPreview out/AppPreview-portrait.mp4",
    "build:landscape": "remotion render AppPreview out/AppPreview-landscape.mp4 --width 1920 --height 886"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "@remotion/transitions": "^4.0.459",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/tailwind": "^4.0.0",
    "@types/react": "^18.3.12",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
